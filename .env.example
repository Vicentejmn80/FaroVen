# FARO — variables de entorno (Vite)

# Supabase — obligatorio para datos operativos
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Cloudflare Turnstile (sitio público, sin secretos)
VITE_TURNSTILE_SITE_KEY=

# OneSignal Web Push (App ID público — va también en Vercel)
VITE_ONESIGNAL_APP_ID=

# Consentimientos legales en Supabase (tabla legal_consents + migraciones aplicadas)
# Dejar vacío o false hasta desplegar la migración; evita 404 en consola.
# VITE_LEGAL_CONSENTS_ENABLED=true

# Logs de push en producción (piloto): VITE_PUSH_DEBUG=true en Vercel
# VITE_PUSH_DEBUG=true

# Push tuning (opcional, solo para troubleshooting fino)
# VITE_PUSH_SUBSCRIBE_TIMEOUT_MS=15000
# VITE_PUSH_INIT_TIMEOUT_MS=10000
# VITE_PUSH_RETRY_ATTEMPTS=3
# VITE_PUSH_RETRY_BASE_MS=300
# VITE_PUSH_CIRCUIT_FAILURE_THRESHOLD=3
# VITE_PUSH_CIRCUIT_COOLDOWN_MS=60000

# NOTA: ONESIGNAL_REST_API_KEY va SOLO en Supabase Edge Function secrets, nunca aquí.
