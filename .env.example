# FARO — variables de entorno (Vite)

# Supabase — obligatorio para datos operativos
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Cloudflare Turnstile (sitio público, sin secretos)
VITE_TURNSTILE_SITE_KEY=

# OneSignal Web Push (App ID público — va también en Vercel)
VITE_ONESIGNAL_APP_ID=

# NOTA: ONESIGNAL_REST_API_KEY va SOLO en Supabase Edge Function secrets, nunca aquí.
