VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_RECAPTCHA_SITE_KEY=your-recaptcha-site-key

# Solo desarrollo local: evita límite de correos de Supabase (≈2/hora)
# Crea el usuario en Dashboard → Authentication → Users → Add user (email + password)
# VITE_DEV_AUTH_EMAIL=coordinador@test.com
# VITE_DEV_AUTH_PASSWORD=tu-password-segura

# Supabase Dashboard → Authentication → URL Configuration:
# Site URL: http://localhost:5173
# Redirect URLs (agrega todas):
#   http://localhost:5173/auth
#   http://localhost:5173/auth?redirect=/volunteer
#   http://localhost:5173/prototype-v3.html
#   http://localhost:5173/prototype-v3.html?view=coordinator
#   http://localhost:5173/prototype-v3.html?view=admin
#
# Authentication → Providers → Email:
#   Desactiva "Confirm email" para login por código (recomendado en desarrollo)
#
# Authentication → Providers → Google (si usas "Continuar con Google"):
#   1. Google Cloud Console → APIs & Services → Credentials → OAuth client (Web)
#   2. Authorized redirect URI: https://TU-PROYECTO.supabase.co/auth/v1/callback
#   3. Pega Client ID y Secret en Supabase → Google → Enable
#
# Authentication → Providers → Phone (si usas SMS):
#   1. Cuenta Twilio con SMS habilitado
#   2. Supabase → Phone → Twilio SID, Auth Token, número o Messaging Service
#   3. Los números deben estar en formato +58… (la app ya los normaliza)
